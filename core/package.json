{
  "name": "@agentx402-ai/core",
  "version": "0.1.0",
  "description": "Shared auth/pay/usage/error/retry plumbing extracted from @agentkv/client, for reuse across agentx402 service SDKs",
  "license": "MIT",
  "author": "The AgentKV Authors <contact@agentx402.ai>",
  "homepage": "https://github.com/agentx402-ai/agentkv#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentx402-ai/agentkv.git",
    "directory": "core"
  },
  "bugs": {
    "url": "https://github.com/agentx402-ai/agentkv/issues"
  },
  "keywords": [
    "agentx402",
    "x402",
    "eip-3009",
    "eip-712",
    "viem",
    "sdk-core"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@x402/core": "^2.16.0",
    "@x402/evm": "^2.16.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
